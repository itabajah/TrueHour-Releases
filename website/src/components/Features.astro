---
const features = [
  {
    title: "Smart Import",
    description: "Drag & drop attendance files. Auto-dedup, instant preview, re-import safe.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
    </svg>`,
  },
  {
    title: "Anomaly Detection",
    description: "Intelligent severity scoring with confidence-based one-click resolution.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
    </svg>`,
  },
  {
    title: "Payroll Export",
    description: "Excel with live formulas and subtotals, or CSV. Print-ready reports.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
    </svg>`,
  },
  {
    title: "Fully Encrypted",
    description: "AES-256 database encryption. Your data stays yours, always.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
    </svg>`,
  },
  {
    title: "Multilingual",
    description: "English, Hebrew, Arabic with full right-to-left layout support.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802" />
    </svg>`,
  },
  {
    title: "Version History",
    description: "Full undo/redo with snapshot branching. Never lose work.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>`,
  },
];
---

<section id="features" class="section-padding relative">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16 lg:mb-20">
      <h2
        data-animate="fade-up"
        class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-theme-heading mb-4"
      >
        Everything you need.
        <br />
        <span class="text-theme-muted">Nothing you don't.</span>
      </h2>
      <div data-animate="fade-up" class="w-16 h-1 bg-accent mx-auto rounded-full mt-6"></div>
    </div>

    <!-- Feature Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {
        features.map((feature, i) => (
          <div
            data-animate="stagger-up"
            class="glass-card p-8 group hover:bg-white/[0.06] transition-all duration-500
                   hover:shadow-xl hover:shadow-primary/5 hover:-translate-y-1"
          >
            {/* Icon */}
            <div class="w-14 h-14 rounded-xl bg-primary/30 flex items-center justify-center mb-5
                        text-primary-light group-hover:bg-accent/20 group-hover:text-accent
                        transition-all duration-500">
              <Fragment set:html={feature.icon} />
            </div>
            {/* Title */}
            <h3 class="text-xl font-semibold text-theme-heading mb-3">{feature.title}</h3>
            {/* Description */}
            <p class="text-theme-muted leading-relaxed text-sm">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Background glow -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px]
           bg-primary/10 rounded-full blur-[120px] pointer-events-none"
    aria-hidden="true"
  ></div>
</section>
