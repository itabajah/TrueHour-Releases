---
const steps = [
  {
    num: "01",
    title: "Import",
    description: "Drop your attendance file — .dat or .txt from any ZKTeco terminal.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m6.75 12l-3-3m0 0l-3 3m3-3v6m-1.5-15H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
    </svg>`,
  },
  {
    num: "02",
    title: "Review",
    description: "Fix anomalies in one click with confidence-scored suggestions.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
    </svg>`,
  },
  {
    num: "03",
    title: "Export",
    description: "Download payroll-ready Excel reports with live formulas.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
    </svg>`,
  },
];
---

<section class="section-padding relative overflow-hidden">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16 lg:mb-20">
      <h2
        data-animate="fade-up"
        class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-theme-heading mb-4"
      >
        Three steps to payroll.
      </h2>
      <p data-animate="fade-up" class="text-theme-muted text-lg max-w-lg mx-auto">
        From raw attendance data to clean reports in minutes.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
      <!-- Connecting Line (desktop) -->
      <div
        class="hidden md:block absolute top-16 left-[16.67%] right-[16.67%] h-px bg-gradient-to-r from-transparent via-theme-muted/20 to-transparent"
        aria-hidden="true"
      ></div>

      {
        steps.map((step) => (
          <div data-animate="stagger-up" class="flex flex-col items-center text-center group">
            {/* Number + Icon */}
            <div class="relative mb-8">
              <div class="w-32 h-32 rounded-full glass-card flex items-center justify-center
                          group-hover:bg-accent/10 transition-all duration-500 glow-primary">
                <div class="text-primary-light group-hover:text-accent transition-colors duration-500">
                  <Fragment set:html={step.icon} />
                </div>
              </div>
              {/* Step Number */}
              <span class="absolute -top-2 -right-2 w-10 h-10 rounded-full bg-accent text-white
                          flex items-center justify-center text-sm font-bold shadow-lg shadow-accent/30">
                {step.num}
              </span>
            </div>
            {/* Title */}
            <h3 class="text-2xl font-bold text-theme-heading mb-3">{step.title}</h3>
            {/* Description */}
            <p class="text-theme-muted leading-relaxed max-w-xs">{step.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
