---
import dashboardImg from "../assets/dashboard-screenshot.png";
---

<section class="section-padding relative">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2
        data-animate="fade-up"
        class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-theme-heading mb-4"
      >
        Clean interface.
        <span class="text-theme-muted">Powerful features.</span>
      </h2>
    </div>

    <!-- Screenshot Frame -->
    <div data-animate="fade-up" class="relative group">
      <!-- Glow behind -->
      <div
        class="absolute -inset-4 bg-gradient-to-r from-primary/20 via-accent/10 to-primary/20
               rounded-3xl blur-2xl opacity-50 group-hover:opacity-70 transition-opacity duration-700"
        aria-hidden="true"
      ></div>

      <!-- Frame -->
      <div class="relative glass-card rounded-2xl overflow-hidden shadow-2xl shadow-black/20">
        <!-- Screenshot (includes Windows title bar) -->
        <img
          src={dashboardImg.src}
          alt="TrueHour Dashboard — showing employee attendance overview, shift hours, and payroll summary"
          class="w-full h-auto block"
          width={dashboardImg.width}
          height={dashboardImg.height}
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <p data-animate="fade-up" class="text-center text-theme-muted text-sm mt-6">
      Dashboard view — real-time overview of attendance, hours, and payroll data
    </p>
  </div>
</section>
