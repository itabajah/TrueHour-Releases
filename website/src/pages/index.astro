---
import Base from "../layouts/Base.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Features from "../components/Features.astro";
import HowItWorks from "../components/HowItWorks.astro";
import AppPreview from "../components/AppPreview.astro";
import Security from "../components/Security.astro";
import Download from "../components/Download.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<Base>
  <!-- Skip to content (accessibility) -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-lg">
    Skip to content
  </a>
  <Navbar />
  <main id="main-content">
    <Hero />
    <Features />
    <HowItWorks />
    <AppPreview />
    <Security />
    <Download />
  </main>
  <Footer />

  <script>
    import { initScrollAnimations } from "../scripts/scroll-animations";

    document.addEventListener("DOMContentLoaded", async () => {
      // Lazy-load Three.js only when hero canvas is visible
      const canvas = document.getElementById("hero-canvas");
      if (canvas) {
        try {
          const { initHeroScene } = await import("../scripts/three-scene");
          initHeroScene();
        } catch {
          // WebGL unsupported or module load failure — page works without 3D background
        }
      }
      initScrollAnimations();
    });
  </script>
</Base>
